# Production: set in your host's dashboard (Netlify/Vercel). Do not commit real values.
# Required in production if you want PATCH /api/election to work.
# Optional locally: copy to .env.local and set a value to test auth (PATCH will require the header).
ELECTION_UPDATE_SECRET=

